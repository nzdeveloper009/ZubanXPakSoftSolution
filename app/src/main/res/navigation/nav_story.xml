<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_story"
    app:startDestination="@id/storyFragment">

    <fragment
        android:id="@+id/storyFragment"
        android:name="com.android.zubanx.feature.story.StoryFragment"
        android:label="Stories">
        <action
            android:id="@+id/action_story_to_category"
            app:destination="@id/storyCategoryFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/storyCategoryFragment"
        android:name="com.android.zubanx.feature.story.StoryCategoryFragment"
        android:label="Stories">
        <argument
            android:name="categoryId"
            app:argType="string" />
    </fragment>

</navigation>
